---
import Icon from './Icon.astro';
import { partnerWhatsappLink } from '../config';
import { PARTNER_PLANS } from '../data/partnerPlans';

// Card de exemplo usa o pacote Pro na capacidade cheia (70 clientes).
const pro = PARTNER_PLANS.find((p) => p.key === 'pro')!;
const clientesCheios = parseInt(pro.clientes.replace(/\D/g, ''), 10);
const revendaNum = parseFloat(pro.revenda.replace(',', '.'));
const mensalidadeNum = parseFloat(pro.mensalidade.replace(',', '.'));
const receitaTotal = clientesCheios * revendaNum;
const margemTotal = receitaTotal - mensalidadeNum;
const brl = (n: number) =>
  n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
---

<div class="oa-wrap">
  <section class="par-hero">
    <div>
      <span class="oa-eyebrow"
        ><span class="dot"></span>Programa de Parceiros · B2B2C</span
      >
      <h1 class="oa-h1 oa-serif">
        Transforme sua carteira em <em>receita recorrente</em>.
      </h1>
      <p class="oa-sub">
        Seu escritório já tem a confiança do cliente e já é cobrado pela emissão
        de notas. Revenda o NotaZap como solução do seu escritório, capture a
        margem e fortaleça o vínculo — sem desenvolver nada.
      </p>
      <div class="oa-cta-row">
        <a class="oa-btn-primary" href={partnerWhatsappLink()}>
          <Icon name="bubble" size={15} /> Quero ser parceiro
        </a>
        <a class="oa-btn-ghost" href="#pacotes">Ver pacotes e preços →</a>
      </div>
      <div class="par-badges">
        <span class="par-badge"><span class="dot"></span>Marca NotaZap</span>
        <span class="par-badge"><span class="dot"></span>Mensalidade fixa</span>
        <span class="par-badge"><span class="dot"></span>Você define o preço de revenda</span>
      </div>
    </div>

    <!-- Exemplo ilustrativo de margem (pacote Pro, carteira cheia) -->
    <div class="par-card">
      <div class="tag">Exemplo · Pacote Pro</div>
      <div class="par-line">
        {clientesCheios} clientes × R$ {pro.revenda}<span class="v">R$ {brl(receitaTotal)}/mês</span>
      </div>
      <div class="par-line">
        Mensalidade NotaZap<span class="v">− R$ {pro.mensalidade}</span>
      </div>
      <div class="par-line total">
        Sua margem<span class="v">R$ {brl(margemTotal)}/mês</span>
      </div>
      <p class="foot">
        Receita de revenda com a carteira cheia, menos o custo fixo do pacote.
        Você pode cobrar acima de R$ {pro.revenda} e ampliar a margem.
      </p>
    </div>
  </section>
</div>

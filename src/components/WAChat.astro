---
// Réplica fiel do WhatsApp-dark do início real da conversa com o NotaZap.
// Puramente visual (imagem viva), não interativo.
const base = import.meta.env.BASE_URL;
---

<div class="oa-phone" aria-hidden="true">
  <div class="wa-screen">
    <div class="wa-head">
      <span class="wa-av">
        <img src={`${base}assets/mark-green.png`} alt="" />
      </span>
      <div class="wa-meta">
        <div class="wa-name">Nota Zap</div>
        <div class="wa-status">online</div>
      </div>
      <div class="wa-icons">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="13" height="12" rx="2.5"></rect><path d="M15 10l6-3v10l-6-3z"></path></svg>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="10.5" cy="10.5" r="7"></circle><path d="M21 21l-5.2-5.2"></path></svg>
        <svg width="5" height="18" viewBox="0 0 5 18" fill="currentColor"><circle cx="2.5" cy="2.5" r="2"></circle><circle cx="2.5" cy="9" r="2"></circle><circle cx="2.5" cy="15.5" r="2"></circle></svg>
      </div>
    </div>

    <div class="wa-body">
      <div class="wa-day">HOJE</div>

      <div class="wa-out">
        <span class="txt">oi</span>
        <div class="wa-foot">
          <span class="tm">15:06</span>
          <svg class="tk" width="15" height="11" viewBox="0 0 17 11" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 6l3 3 6.5-7.5M6.5 9l.5.5 6.5-7.5"></path></svg>
        </div>
      </div>

      <div class="wa-in">
        <div class="sndr">Nota Zap</div>
        <span class="q">Por gentileza, informe a opção que você deseja:</span>
        <div class="opt">Selecione uma opção</div>
        <div class="tm">15:06</div>
      </div>
      <div class="wa-btns">
        <div class="wa-btn alt">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 4.5L3 8l3.5 3.5M3 8h6.5a3.5 3.5 0 013.5 3.5V12"></path></svg> Nova Nota
        </div>
        <div class="wa-btn">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 4.5L3 8l3.5 3.5M3 8h6.5a3.5 3.5 0 013.5 3.5V12"></path></svg> Cancelar Nota
        </div>
        <div class="wa-btn">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 4.5L3 8l3.5 3.5M3 8h6.5a3.5 3.5 0 013.5 3.5V12"></path></svg> Listar Notas Emitidas
        </div>
        <div class="wa-btn">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 4.5L3 8l3.5 3.5M3 8h6.5a3.5 3.5 0 013.5 3.5V12"></path></svg> Falar com um atendente
        </div>
      </div>

      <div class="wa-out">
        <div class="wa-quote">
          <div class="qn">Nota Zap</div>
          <div class="qt">Por gentileza, informe a opção que você deseja…</div>
        </div>
        <span class="txt">Nova Nota</span>
        <div class="wa-foot">
          <span class="tm">15:06</span>
          <svg class="tk" width="15" height="11" viewBox="0 0 17 11" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 6l3 3 6.5-7.5M6.5 9l.5.5 6.5-7.5"></path></svg>
        </div>
      </div>
    </div>
  </div>
</div>
